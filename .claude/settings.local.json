{
  "env": {
    "WOODPECKER_TOKEN": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0eXBlIjoidXNlciIsInVzZXItaWQiOiIxIn0.9tdGiBnabwZrWe8zXmgd-KDuO0IuNukIMPPTalWVxHc"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "node W:/bored/.claude/watch-woodpecker.js",
            "statusMessage": "Watching Woodpecker CI build...",
            "timeout": 660
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "wsl -e bash -c 'cd /mnt/w/bored && /home/vincent/.cargo/bin/cargo build -p backend -p shared'",
            "statusMessage": "Building before commit...",
            "timeout": 120
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "wsl -e bash -c 'cd /mnt/w/bored && /home/vincent/.cargo/bin/cargo test -p backend -p shared'",
            "statusMessage": "Running unit tests before commit...",
            "timeout": 300
          },
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "wsl -e bash -c 'cd /mnt/w/bored && /home/vincent/.cargo/bin/cargo test -p backend -p shared'",
            "statusMessage": "Running unit tests before push...",
            "timeout": 300
          }
        ]
      }
    ]
  }
}