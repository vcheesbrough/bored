{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "cargo build -p backend -p shared",
            "statusMessage": "Building before commit...",
            "timeout": 120
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "cargo test -p backend -p shared",
            "statusMessage": "Running unit tests before commit...",
            "timeout": 300
          },
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "cargo test -p backend -p shared",
            "statusMessage": "Running unit tests before push...",
            "timeout": 300
          }
        ]
      }
    ]
  }
}